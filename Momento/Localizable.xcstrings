    "Delete folder warning: %@" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” and its subfolders will be deleted. Assets inside the folder will stay in the library, but they will be removed from this folder."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 及其子文件夹将被删除。文件夹中的素材仍会保留在资源库中，但会从这个文件夹移除。"
          }
        }
      }
    },
    "Delete library warning: %@" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” will be moved to the Trash. It will be removed from Momento’s recent libraries, and you can restore the package from the Trash before it is emptied."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 将被移动到废纸篓，并从 Momento 的最近资源库列表中移除。在废纸篓清空之前，你仍然可以从废纸篓中恢复这个资源库包。"
          }
        }
      }
    },
